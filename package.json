{
  "name": "com.sysread.spacer",
  "displayName": "Spacer",
  "version": "1.0.0",
  "description": "A thing named Spacer",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build-wasm": "cd src; for file in $(ls *.zig); do zig build-lib $file -target wasm32-freestanding --output-dir ../www/wasm --single-threaded; done; cd ..; rm www/wasm/*.h && rm www/wasm/*.o",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": "Jeff Ober",
  "license": "Apache-2.0",
  "dependencies": {
    "bootstrap": "~5.3",
    "cordova-android": "^7.1.4",
    "cordova-browser": "^5.0.4",
    "cordova-plugin-device": "^2.0.3",
    "cordova-plugin-statusbar": "^2.4.3",
    "gsap": "~3.12",
    "hammerjs": "^2.0.8",
    "npm": "^6.14.5",
    "sprintf-js": "^1.1.2",
    "statusbar": "^0.2.0",
    "vue": "^2.7.16"
  },
  "cordova": {
    "platforms": [
      "browser",
      "android"
    ],
    "plugins": {
      "cordova-plugin-statusbar": {},
      "cordova-plugin-device": {}
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "cordova": "^9.0.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
