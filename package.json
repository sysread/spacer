{
  "name": "com.sysread.spacer",
  "displayName": "Spacer",
  "version": "1.0.0",
  "description": "A thing named Spacer",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build-wasm": "cd src; for file in $(ls *.zig); do zig build-lib $file -target wasm32-freestanding --output-dir ../www/wasm --single-threaded; done; cd ..; rm www/wasm/*.h && rm www/wasm/*.o",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": "Jeff Ober",
  "license": "Apache-2.0",
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "bootstrap": "~5.3",
    "gsap": "~3.14",
    "hammerjs": "^2.0.8",
    "sprintf-js": "^1.1.2",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.0"
  }
}
